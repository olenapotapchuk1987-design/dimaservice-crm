{
  "name": "dimaservice-crm",
  "version": "6.5.0",
  "description": "DimaService CRM",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build-mac": "electron-builder --mac",
    "build-all": "electron-builder --win --mac --x64"
  },
  "build": {
    "appId": "it.dimaservice.crm",
    "productName": "DimaService CRM",
    "copyright": "DimaService",
    "directories": {
      "output": "dist"
    },
  "files": [
  "main.js",
  "index.html",
  "icon.png",
  "icon.ico"
],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "icon.png",
      "category": "public.app-category.business"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DimaService CRM"
    },
    "dmg": {
      "title": "DimaService CRM",
      "icon": "icon.png",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
